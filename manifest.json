{
  "manifest_version": 3,
  "name": "SET Thailand Stock Analyzer",
  "version": "1.0.0",
  "description": "Real-time Thai stock data from SET.OR.TH — financials, chart, shareholders & profile.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "SET Thailand Stock Analyzer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "declarativeNetRequest"],
  "host_permissions": [
    "https://www.set.or.th/*"
  ]
}
